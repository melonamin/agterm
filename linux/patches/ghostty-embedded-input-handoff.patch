diff --git i/src/renderer/State.zig w/src/renderer/State.zig
index 8693458..71fc494 100644
--- i/src/renderer/State.zig
+++ w/src/renderer/State.zig
@@ -75,6 +75,29 @@ pub fn lockDemand(self: *State) void {
 /// parked in `yieldToDemand` that the demanding waiter had its turn.
 pub fn unlockDemand(self: *State) void {
     self.mutex.unlock();
+    self.finishDemand();
+}
+
+/// Keep demand asserted across a host callback that may take the raw mutex
+/// one or more times. Embedded hosts call core surface APIs synchronously on
+/// their UI thread, so those calls need the same handoff guarantee as the
+/// renderer or sustained PTY output can starve keyboard and focus handling.
+pub fn demandGuard(self: *State) DemandGuard {
+    _ = self.demand.fetchAdd(1, .monotonic);
+    return .{ .state = self };
+}
+
+pub const DemandGuard = struct {
+    state: *State,
+
+    pub fn deinit(self: DemandGuard) void {
+        const prev = self.state.demand.fetchSub(1, .monotonic);
+        assert(prev > 0);
+        self.state.finishDemand();
+    }
+};
+
+fn finishDemand(self: *State) void {
     _ = self.handoff_gen.fetchAdd(1, .monotonic);
     std.Thread.Futex.wake(&self.handoff_gen, 1);
 }
