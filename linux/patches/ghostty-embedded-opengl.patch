diff --git i/src/renderer/OpenGL.zig w/src/renderer/OpenGL.zig
index 4b01da0..5148c36 100644
--- i/src/renderer/OpenGL.zig
+++ w/src/renderer/OpenGL.zig
@@ -160,19 +160,24 @@ fn prepareContext(getProcAddress: anytype) !void {

 /// This is called early right after surface creation.
 pub fn surfaceInit(surface: *apprt.Surface) !void {
-    _ = surface;
-
     switch (apprt.runtime) {
         else => @compileError("unsupported app runtime for OpenGL"),

         // GTK uses global OpenGL context so we load from null.
-        apprt.gtk,
-        => try prepareContext(null),
+        apprt.gtk => try prepareContext(null),

+        // The host (e.g. a GtkGLArea) owns the GL context. Make it current on
+        // this (app) thread, then load glad against it. glad's context is
+        // threadlocal and all embedded-OpenGL draws run on this same host
+        // thread (must_draw_from_app_thread), so loading here is correct.
         apprt.embedded => {
-            // TODO(mitchellh): this does nothing today to allow libghostty
